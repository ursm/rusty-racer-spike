# Cargo build artifacts — at the workspace root AND in the nested extension
# (ext/rusty_racer/target/, which a leading-slash /target would miss).
target/
# Stray rustc/cargo lib artifacts that can escape target/ (e.g. a libtest_glob
# .rlib dropped in the repo root by a tool run).
*.rlib

# Ruby/gem build artifacts
*.so
*.bundle
/pkg/
/tmp/
/Gemfile.lock
